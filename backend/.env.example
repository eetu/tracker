# Local dev config — cp .env.example .env (gitignored), run from backend/
# (`cargo run`). All optional except TRACKER_ROOT; defaults in src/config.rs.
# Prod gets env from the raspi quadlet.

# Dev auth: /api/* is reachable without oauth2-proxy forward-auth headers.
# Never in prod.
DEV_AUTH=1

# Root of the module collection to scan. On the Mac this is the NAS mount;
# on the Pi it's the in-container mount (/mods).
TRACKER_ROOT=/Volumes/mods

# SQLite cache (path index + parsed metadata). Repo root, gitignored.
TRACKER_DB_PATH=../tracker.db

# Built SPA to serve (yarn build). With the Vite dev server (yarn dev on
# :5173) the proxy talks to :3010 either way.
STATIC_DIR=../frontend/dist

# TRACKER_BIND=0.0.0.0:3010
# RUST_LOG=info,tracker_backend=debug
